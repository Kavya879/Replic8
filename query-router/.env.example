PORT=3000
# Optional API key. When set, POST /query and the metrics WebSocket require it.
# Send it as "Authorization: Bearer <key>" or "X-API-Key: <key>" for HTTP, and as
# "?token=<key>" for the WebSocket. Leave empty to run unauthenticated.
API_KEY=
PRIMARY_DB_HOST=postgres-primary
PRIMARY_DB_PORT=5432
PRIMARY_DB_NAME=appdb
PRIMARY_DB_USER=postgres
PRIMARY_DB_PASSWORD=change-me-primary-password
REPLICA_DB_HOSTS=postgres-replica-1,postgres-replica-2
REPLICA_DB_PORT=5432
REPLICA_DB_NAME=appdb
REPLICA_DB_USER=postgres
REPLICA_DB_PASSWORD=change-me-primary-password
POOL_MAX=10
POOL_CONNECTION_TIMEOUT_MS=5000