POSTGRES_USER=postgres
POSTGRES_DB=appdb
POSTGRES_PASSWORD=change-me-primary-password
REPLICATION_USER=replicator
REPLICATION_PASSWORD=change-me-replication-password

# Optional. When set, the Query Router requires this key on POST /query
# (Authorization: Bearer <key> or X-API-Key: <key>) and on the metrics WebSocket
# (?token=<key>). Leave empty to run unauthenticated (a startup warning is logged).
API_KEY=

# Grafana admin credentials (dashboards at http://localhost:3001).
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin